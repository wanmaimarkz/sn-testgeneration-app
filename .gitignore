# --- Next.js / Node.js (Frontend) ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env*.local
frontend/npm-debug.log*

# --- FastAPI / Python (Backend) ---
# จัดการ virtual environment
backend/.venv/
**/venv/
backend/venv/*

# Cache และไฟล์คอมไพล์ต่างๆ
**/__pycache__/
**/*.py[cod]
**/*.pyc
backend/.env
backend/.pytest_cache/

# --- Local LLM & Models ---
# ยกเว้นไฟล์โมเดลในโฟลเดอร์ local แต่ยังคงโฟลเดอร์ไว้
backend/local/*
!backend/local/.gitkeep

# --- Database ---
# ยกเว้นไฟล์ database แต่ยังคงโครงสร้างโฟลเดอร์ database/relational หรือ vector ไว้
backend/database/**/*.db
backend/database/**/*.sqlite3
backend/database/vector/*
backend/database/relational/*
# หากต้องการ ignore ทุกอย่างใน database ยกเว้นโฟลเดอร์ว่าง
# backend/database/*
# !backend/database/.gitkeep

# --- OS / IDE Files ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Electron / Build ---
dist/
*.executable

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Evaluation
eval